# BothSafe backend — environment template.
# Copy to .env and fill in real values. Never commit .env.

# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3003
APP_BASE_URL=http://localhost:3000
# Where the frontend lives. Used to build deal links, redirect URIs, etc.

# ─── Database (PostgreSQL via bothsafe-dev-postgres docker container) ─────────
# Dev container exposes 5432 internally, mapped to host 55432 to avoid
# colliding with other postgres instances on this dev machine.
DATABASE_URL="postgresql://bothsafe:bothsafe@localhost:55432/bothsafe?schema=public"

# Optional: separate connection string for `prisma migrate` (DDL).
# When set, the Prisma CLI uses this URL; runtime queries still use
# DATABASE_URL. In production this should authenticate as the `migrator`
# role created by backend/prisma/sql/append_only_enforcement.sql, while
# DATABASE_URL above authenticates as the `app` role. In dev the single
# `bothsafe` superuser is fine, so this is left unset by default.
# MIGRATE_DATABASE_URL=postgresql://migrator:CHANGEME@localhost:55432/bothsafe?schema=public

# ─── Cache / queue (bothsafe-dev-redis docker container) ──────────────────────
REDIS_URL=redis://localhost:56379

# ─── Object storage (bothsafe-dev-minio docker container) ─────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=59000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bothsafe

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT_SECRET must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=replace-with-32+char-random-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=replace-with-random-session-secret
ENCRYPTION_MASTER_KEY=replace-with-base64-32-byte-key
SESSION_TTL_DAYS=30

# ─── Deal flow tuning ─────────────────────────────────────────────────────────
INVITE_TOKEN_TTL_HOURS=72
DEAL_EXPIRES_HOURS=720
PLATFORM_FEE_PERCENT=2
DEFAULT_CURRENCY=USD
RECEIVER_ACCOUNT_LABEL="BothSafe Escrow (Bakong)"

# ─── Bakong / KHQR (BothSafe receiving account) ───────────────────────────────
# Register at https://bakong.nbc.gov.kh to obtain BAKONG_ACCOUNT_ID + API token.
BAKONG_ACCOUNT_ID=your_account_id@bank
BAKONG_MERCHANT_NAME=BothSafe Escrow
BAKONG_MERCHANT_CITY=Phnom Penh
BAKONG_API_TOKEN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowlist. Empty in development = allow all origins.
# In production you MUST set this to your real frontend origin(s).
CORS_ORIGINS=

# ─── Telegram bot (in-process NestJS module) ──────────────────────────────────
# Set TELEGRAM_BOT_ENABLED=true once you have a real token from @BotFather.
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=BothSafeBot
TELEGRAM_WEBHOOK_SECRET=replace-with-random-string
TELEGRAM_WEBHOOK_URL=http://localhost:3003/webhooks/telegram

# Telegram OIDC (for sign-in via Telegram). From BotFather → Bot Settings → Web Login.
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=

# ─── Google OAuth (sign-in) ───────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Backend URL used to build redirect_uri for OAuth callbacks.
AUTH_CALLBACK_BASE_URL=http://localhost:3003

# ─── Admin bootstrap ──────────────────────────────────────────────────────────
# On first boot the backend creates this admin if no admin exists.
# Password must be at least 8 characters.
ADMIN_BOOTSTRAP_EMAIL=admin@bothsafe.local
ADMIN_BOOTSTRAP_PASSWORD=change-me-on-first-login

# ─── Append-only enforcement SQL (dev only) ───────────────────────────────────
# Passwords used by backend/prisma/sql/append_only_enforcement.sql when it
# CREATE-ROLEs the `migrator` and `app` roles. Override these in production
# from your secret manager — never commit real values. Both env vars are
# only consumed by psql while applying that script; the running backend
# does NOT read them.
# DEV ONLY: example MIGRATOR_PASSWORD/APP_PASSWORD for append-only-enforcement.sql
MIGRATOR_PASSWORD=dev-migrator-pwd
APP_PASSWORD=dev-app-pwd
